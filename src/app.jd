importar src/entidades/Produto
importar src/entidades/Cliente
importar src/entidades/Venda
importar src/servicos/estoqueService

tela Dashboard "Dashboard"
  divisor ResumoDia
    rotulo: "Resumo do dia"
  fim
  cartao TotalVendas
    titulo: "Total de Vendas"
    conteudo: soma(Venda.total)
    variante: sucesso
  fim
  cartao TotalProdutos
    titulo: "Produtos Cadastrados"
    conteudo: contagem(Produto)
    variante: info
  fim
  cartao TotalClientes
    titulo: "Clientes Ativos"
    conteudo: contagem(Cliente)
    variante: primario
  fim
  cartao TicketMedio
    titulo: "Ticket Médio"
    conteudo: media(Venda.total)
    variante: aviso
  fim
  grafico VendasSemana
    tipo: barras
    entidade: Venda
    eixoX: criadaEm
    eixoY: total
  fim
  lista AlertasProdutos
    entidade: Produto
    campo: nome
    subcampo: estoque
  fim
fim

tela TelaProdutos "Produtos"
  toolbar AcoesProdutos
    botao: "Novo Produto|novoProduto|mais|primario"
    botao: "Exportar|exportarCSV|compartilhar|secundario"
  fim
  tabela ListaProdutos
    entidade: Produto
    colunas: nome, preco, estoque, estoqueMinimo, ativo
    filtravel: verdadeiro
    ordenavel: verdadeiro
    paginacao: 20
    acoes: editar, excluir
  fim
fim

tela TelaClientes "Clientes"
  toolbar AcoesClientes
    botao: "Novo Cliente|novoCliente|mais|primario"
  fim
  tabela ListaClientes
    entidade: Cliente
    colunas: nome, email, telefone, cidade, ativo
    filtravel: verdadeiro
    ordenavel: verdadeiro
    paginacao: 20
    acoes: editar, excluir
  fim
fim

tela TelaVendas "Vendas"
  toolbar AcoesVendas
    botao: "Nova Venda|novaVenda|mais|primario"
    botao: "Exportar CSV|exportarCSV|compartilhar|secundario"
  fim
  divisor ResumoMes
    rotulo: "Resumo do mês"
  fim
  cartao TotalDoMes
    titulo: "Total do Mês"
    conteudo: soma(Venda.total)
    variante: sucesso
  fim
  cartao TicketMedioVendas
    titulo: "Ticket Médio"
    conteudo: media(Venda.total)
    variante: info
  fim
  grafico GraficoVendas
    tipo: linha
    entidade: Venda
    eixoX: criadaEm
    eixoY: total
  fim
  tabela TabelaVendas
    entidade: Venda
    colunas: clienteNome, total, status, criadaEm
    filtravel: verdadeiro
    ordenavel: verdadeiro
    paginacao: 20
    acoes: editar, excluir
  fim
fim

tela App "ERP Demo"
  gaveta MenuPrincipal
    item: "Dashboard|casa|Dashboard"
    item: "Produtos|caixa|TelaProdutos"
    item: "Clientes|usuarios|TelaClientes"
    item: "Vendas|moeda|TelaVendas"
  fim
fim
